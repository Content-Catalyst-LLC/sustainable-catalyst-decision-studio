{
  "release": "1.9.0",
  "release_name": "Decision Governance and Review Center",
  "release_date": "2026-07-16",
  "build_fingerprint": "scds-v1.9.0-decision-governance",
  "source_commit": "release-v1.9.0",
  "schemas": {
    "decision_packet": "scds-decision-packet/1.2",
    "platform_artifact": "scds-platform-artifact/1.0",
    "evidence_record": "scds-evidence-record/1.0",
    "decision_governance": "scds-decision-governance/1.0",
    "review_event": "scds-review-event/1.0"
  },
  "wordpress": {
    "plugin_version": "1.9.0",
    "database_version": "1.3.0",
    "api_namespace": "scds/v1",
    "governance_table_storage": "projects.governance_json"
  },
  "backend": {
    "version": "1.9.0",
    "root_dir": "backend",
    "start_command": "uvicorn app.main:app --host 0.0.0.0 --port $PORT"
  },
  "platform_products": [
    "knowledge-library",
    "research-librarian",
    "site-intelligence",
    "workbench",
    "research-lab",
    "platform-core"
  ],
  "governance": {
    "states": [
      "draft",
      "evidence_gathering",
      "analysis",
      "review",
      "revision_required",
      "approved",
      "rejected",
      "deferred",
      "implemented",
      "retired"
    ],
    "approval_controls": [
      "named accountable decision owner",
      "completed human reviewer assignment",
      "satisfied or waived required approval conditions",
      "resolved material exceptions",
      "mitigated or recused conflicts of interest",
      "decision-owner sign-off",
      "independent governance or review sign-off"
    ],
    "immutable_review_history": true,
    "governance_aware_export_restrictions": true,
    "ai_approval_allowed": false
  },
  "limits": {
    "max_request_bytes": 1048576,
    "public_rate_limit": 60,
    "window_seconds": 60,
    "batch_import_maximum": 100,
    "governance_record_maximum": 100,
    "review_history_maximum": 1000
  },
  "compatibility": {
    "shortcodes_preserved": true,
    "rest_routes_preserved": true,
    "packet_schema_breaking_changes": false,
    "typed_platform_artifacts": true,
    "legacy_artifact_adapters_preserved": true,
    "v1_8_handoff_contracts_preserved": true
  },
  "checks": [
    "backend tests",
    "governance transition tests",
    "approval blocker tests",
    "review-history tamper detection",
    "governance export restriction tests",
    "backend compile",
    "JavaScript syntax",
    "PHP syntax",
    "JSON validation",
    "typed contract validation",
    "legacy adapter compatibility",
    "version parity",
    "plugin package structure"
  ]
}
