    "analyses": [
      "weighted ranking",
      "unweighted ranking",
      "one-way sensitivity",
      "tornado ranking",
      "two-variable screening grid",
      "threshold and break-even search",
      "uncertainty envelopes",
      "time-horizon comparison",
      "stakeholder distribution",
      "dominance analysis",
      "reversibility and option value"
    ],
