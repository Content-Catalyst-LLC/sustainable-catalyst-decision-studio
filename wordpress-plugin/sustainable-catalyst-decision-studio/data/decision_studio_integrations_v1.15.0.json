  "governance_schema": "scds-decision-governance/1.0",
  "review_event_schema": "scds-review-event/1.0",
  "governance_center": {
    "packet_section": "governance_center",
    "states": [
      "draft",
      "evidence_gathering",
      "analysis",
      "review",
      "revision_required",
      "approved",
      "rejected",
      "deferred",
      "implemented",
      "retired"
    ],
    "routes": [
      "GET /governance/states",
      "GET /governance/template",
      "POST /governance/evaluate",
      "POST /governance/transition",
      "POST /decision-packet/governance",
      "POST /governance/history/verify"
    ],
    "approval_is_human_only": true,
    "review_history": "append-only SHA-256 hash chain",
    "export_restrictions": [
      "reviewed",
      "public"
    ]
  },
  "scenario_studio_schema": "scds-scenario-studio/1.0",
