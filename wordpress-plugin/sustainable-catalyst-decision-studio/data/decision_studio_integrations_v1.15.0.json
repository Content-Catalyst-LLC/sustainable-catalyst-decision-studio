      "step": 1,
      "phase": "Source",
      "product_id": "knowledge-library",
      "product_name": "Knowledge Library",
      "packet_section": "evidence_registry"
    },
    {
      "step": 2,
      "phase": "Route",
      "product_id": "research-librarian",
      "product_name": "Research Librarian",
      "packet_section": "research_routes"
    },
    {
      "step": 3,
      "phase": "Observe",
      "product_id": "site-intelligence",
      "product_name": "Site Intelligence",
      "packet_section": "live_evidence"
    },
    {
      "step": 4,
      "phase": "Calculate",
      "product_id": "workbench",
      "product_name": "Workbench",
      "packet_section": "calculation_trace"
    },
    {
      "step": 5,
      "phase": "Test",
      "product_id": "research-lab",
      "product_name": "Research Lab",
      "packet_section": "experimental_evidence"
    },
    {
      "step": 6,
      "phase": "Connect",
      "product_id": "platform-core",
      "product_name": "Platform Core",
      "packet_section": "platform_registry"
    },
    {
      "step": 7,
      "phase": "Decide",
      "product_id": "decision-studio",
      "product_name": "Decision Studio",
      "packet_section": "integrated_decision_brief"
    }
  ],
  "contracts": [
